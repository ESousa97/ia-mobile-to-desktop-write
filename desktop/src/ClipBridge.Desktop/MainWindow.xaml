<ui:FluentWindow x:Class="ClipBridge.Desktop.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="ClipBridge"
                 Width="560" Height="640"
                 MinWidth="480" MinHeight="560"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="ClipBridge" />

        <ScrollViewer Grid.Row="1" Padding="24,12,24,24" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Cabeçalho -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <ui:SymbolIcon Symbol="Link24" FontSize="28" VerticalAlignment="Center" />
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="ClipBridge" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock Text="Área de transferência compartilhada · rede local"
                                   Opacity="0.7" FontSize="12" />
                    </StackPanel>
                </StackPanel>

                <!-- Status da conexão -->
                <ui:Card Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon x:Name="StatusIcon" Symbol="PlugDisconnected24" FontSize="24"
                                       VerticalAlignment="Center" />
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Status" Opacity="0.7" FontSize="12" />
                            <TextBlock x:Name="StatusText" Text="Servidor parado" FontSize="15" FontWeight="Medium" />
                        </StackPanel>
                    </StackPanel>
                </ui:Card>

                <!-- Atalho: captura de tela -->
                <ui:Card Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Camera24" FontSize="22" VerticalAlignment="Center" />
                            <TextBlock Text="Captura de tela em alta definição" Margin="12,0,0,0"
                                       FontSize="15" FontWeight="Medium" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Margin="0,8,0,8" Opacity="0.75" TextWrapping="Wrap"
                                   Text="Atalho global Ctrl + F captura a tela inteira em resolução física real e salva um PNG sem perda." />
                        <ui:Button x:Name="CaptureButton" Content="Capturar agora" Icon="{ui:SymbolIcon Camera24}"
                                   Click="OnCaptureClick" HorizontalAlignment="Left" />
                    </StackPanel>
                </ui:Card>

                <!-- Atalho: digitação simulada -->
                <ui:Card Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Keyboard24" FontSize="22" VerticalAlignment="Center" />
                            <TextBlock Text="Digitar o texto copiado" Margin="12,0,0,0"
                                       FontSize="15" FontWeight="Medium" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Margin="0,8,0,8" Opacity="0.75" TextWrapping="Wrap"
                                   Text="Atalho global Ctrl + F1 digita o texto da área de transferência caractere a caractere, como o teclado físico (útil onde Ctrl+V é bloqueado)." />
                        <ui:Button x:Name="TypeButton" Content="Digitar em 3s" Icon="{ui:SymbolIcon Keyboard24}"
                                   Click="OnTypeClick" HorizontalAlignment="Left" />
                    </StackPanel>
                </ui:Card>

                <!-- Log -->
                <ui:Card>
                    <StackPanel>
                        <TextBlock Text="Atividade" FontSize="13" FontWeight="Medium" Margin="0,0,0,6" Opacity="0.8" />
                        <TextBox x:Name="LogBox" IsReadOnly="True" MinHeight="120" MaxHeight="160"
                                 VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                                 Background="Transparent" BorderThickness="0" FontFamily="Consolas" FontSize="12" />
                    </StackPanel>
                </ui:Card>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
