<ui:FluentWindow x:Class="Beam.Desktop.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Beam"
                 Width="560" Height="640"
                 MinWidth="480" MinHeight="560"
                 ShowInTaskbar="False"
                 Visibility="Hidden"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Beam" />

        <ScrollViewer Grid.Row="1" Padding="24,12,24,24" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Cabeçalho -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <ui:SymbolIcon Symbol="Link24" FontSize="28" VerticalAlignment="Center" />
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Beam" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock Text="Área de transferência compartilhada · rede local"
                                   Opacity="0.7" FontSize="12" />
                    </StackPanel>
                </StackPanel>

                <!-- Status da conexão -->
                <ui:Card Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon x:Name="StatusIcon" Symbol="PlugDisconnected24" FontSize="24"
                                       VerticalAlignment="Center" />
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Status" Opacity="0.7" FontSize="12" />
                            <TextBlock x:Name="StatusText" Text="Servidor parado" FontSize="15" FontWeight="Medium" />
                        </StackPanel>
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Password24" FontSize="28" VerticalAlignment="Center" />
                        <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Parear dispositivo" FontSize="15" FontWeight="Medium" />
                            <TextBlock Text="Digite este código no ClipBridge Mobile."
                                       Margin="0,6,0,0" Opacity="0.75" TextWrapping="Wrap" />
                            <TextBlock Text="Código de autenticação" Margin="0,10,0,0" Opacity="0.7" FontSize="12" />
                            <TextBlock x:Name="PairingCodeText" FontFamily="Consolas" FontSize="24" FontWeight="Bold" />
                            <TextBlock Text="Endereço na rede (para conexão manual)" Margin="0,10,0,0"
                                       Opacity="0.7" FontSize="12" />
                            <TextBlock x:Name="AddressText" FontFamily="Consolas" FontSize="14"
                                       TextWrapping="Wrap" Text="—" />
                            <TextBlock x:Name="TrustText" Margin="0,10,0,0" Opacity="0.75" TextWrapping="Wrap"
                                       Text="Nenhum celular com reconexão automática." />
                            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                <ui:Button Content="Gerar novo código" Icon="{ui:SymbolIcon ArrowSync24}"
                                           Click="OnRefreshPairingClick" />
                                <ui:Button x:Name="RevokeButton" Content="Revogar dispositivos"
                                           Icon="{ui:SymbolIcon Prohibited24}" Margin="8,0,0,0"
                                           Click="OnRevokeTrustClick" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ui:Card>

                <!-- Firewall: sem a regra de entrada o Windows descarta a conexão do celular -->
                <ui:Card Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon x:Name="FirewallIcon" Symbol="ShieldError24" FontSize="22"
                                           VerticalAlignment="Center" />
                            <TextBlock Text="Acesso pela Wi-Fi" Margin="12,0,0,0"
                                       FontSize="15" FontWeight="Medium" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock x:Name="FirewallText" Margin="0,8,0,8" Opacity="0.75" TextWrapping="Wrap"
                                   Text="Verificando as regras do Firewall do Windows…" />
                        <ui:Button x:Name="FirewallButton" Content="Liberar no Firewall"
                                   Icon="{ui:SymbolIcon ShieldCheckmark24}"
                                   Click="OnAllowFirewallClick" HorizontalAlignment="Left" />
                    </StackPanel>
                </ui:Card>

                <!-- Atalho: captura de tela -->
                <ui:Card Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Camera24" FontSize="22" VerticalAlignment="Center" />
                            <TextBlock Text="Captura de tela em alta definição" Margin="12,0,0,0"
                                       FontSize="15" FontWeight="Medium" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Margin="0,8,0,8" Opacity="0.75" TextWrapping="Wrap"
                                   Text="Atalho global Ctrl + F captura a tela inteira em resolução física real e salva um PNG sem perda." />
                        <ui:Button x:Name="CaptureButton" Content="Capturar agora" Icon="{ui:SymbolIcon Camera24}"
                                   Click="OnCaptureClick" HorizontalAlignment="Left" />
                    </StackPanel>
                </ui:Card>

                <!-- Atalho: digitação simulada -->
                <ui:Card Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Keyboard24" FontSize="22" VerticalAlignment="Center" />
                            <TextBlock Text="Digitar o texto copiado" Margin="12,0,0,0"
                                       FontSize="15" FontWeight="Medium" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Margin="0,8,0,8" Opacity="0.75" TextWrapping="Wrap"
                                   Text="Atalho global Ctrl + F1 digita o texto da área de transferência caractere a caractere, como o teclado físico (útil onde Ctrl+V é bloqueado)." />
                        <ui:Button x:Name="TypeButton" Content="Digitar em 3s" Icon="{ui:SymbolIcon Keyboard24}"
                                   Click="OnTypeClick" HorizontalAlignment="Left" />
                    </StackPanel>
                </ui:Card>

                <!-- Log -->
                <ui:Card>
                    <StackPanel>
                        <TextBlock Text="Atividade" FontSize="13" FontWeight="Medium" Margin="0,0,0,6" Opacity="0.8" />
                        <TextBox x:Name="LogBox" IsReadOnly="True" MinHeight="120" MaxHeight="160"
                                 VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                                 Background="Transparent" BorderThickness="0" FontFamily="Consolas" FontSize="12" />
                    </StackPanel>
                </ui:Card>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
